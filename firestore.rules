rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isOwner(uid) { return signedIn() && request.auth.uid == uid; }
    function isAdmin() {
      return signedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Users can read social data when signed in, but can only write their own user doc + subcollections.
    match /users/{uid} {
      allow read: if signedIn();
      allow create, update: if isOwner(uid);
      allow delete: if false;

      match /progress/{lessonId} {
        allow read, write: if isOwner(uid);
      }

      match /private/{docId} {
        allow read, write: if isOwner(uid)
          && (docId == "progress" || docId == "progress_greek" || docId == "progress_hebrew");
      }

      match /activity/{activityId} {
        allow read, write: if isOwner(uid);
      }

      // Inbox-style notifications: anyone signed in can create a notification for a user,
      // but only the recipient can read/update/delete it.
      match /notifications/{notificationId} {
        allow read: if isOwner(uid);
        allow create: if signedIn()
          && request.resource.data.fromUid == request.auth.uid
          && request.resource.data.read == false;
        allow update, delete: if isOwner(uid);
      }
    }

    // Denormalized leaderboard rows.
    match /leaderboard/{uid} {
      allow read: if signedIn();
      allow create, update: if isOwner(uid);
      allow delete: if false;
    }

    // Public activity feed (used by Admin Portal).
    match /activities/{activityId} {
      // Reads are allowed for signed-in users; UI can still filter by visibility.
      allow read: if signedIn();
      // Writes allowed for signed-in users (optionally restrict to own actorUid).
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }

    // Admin-created study groups (Admin Portal).
    match /study_groups/{groupId} {
      allow read, write: if isAdmin();
    }

    // Admin announcements (Admin Portal).
    match /announcements/{announcementId} {
      allow read, write: if isAdmin();
    }

    // Study rooms: members can read/update; host can delete.
    match /studyRooms/{roomId} {
      allow create: if signedIn() && request.resource.data.host == request.auth.uid;
      allow read, update: if signedIn() && request.auth.uid in resource.data.members;
      allow delete: if signedIn() && resource.data.host == request.auth.uid;
    }

    // Practice highscores (daily): public reads for signed-in; users can only write their own row.
    match /practiceScores/{scoreId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    // Lessons content: any authenticated user can read lessons.
    // Write/delete behavior remains unchanged (falls through to global deny).
    match /lessons/{lessonId} {
      allow read: if signedIn();
    }

    // Lock down everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
